<% if defined?(@context) && !@context.blank? %>
<div class="container-fluid p-0 clear">
    <nav aria-label="<%= I18n.t('navigation.hierarchical') %>">
      	  <ul class="breadcrumb">
		  <li><a href="https://library.buffalo.edu">University Libraries</a></li>
		  <li><a href="/">Archival &amp; Manuscript Collections</a></li>
		  
	<% @context.each do |bread| %>
	<% if bread[:crumb]; crumb = bread[:crumb]; crumb += " (#{bread[:identifier]})" if bread[:identifier] %>
	<li>
	 
	  <% if bread[:uri].blank? %>
	    <%= process_mixed_content(crumb).html_safe %>
	  <% else %>
	    <a href='<%=app_prefix(bread[:uri]) %>'>
		<%= process_mixed_content(crumb).html_safe %>
	    </a>
	  <% end %>
	</li>
	<% end %>
	<% end %>
      </ul>
    </nav>
</div>
<% end %>
